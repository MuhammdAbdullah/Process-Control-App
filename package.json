{
  "name": "process-control-temperature-app",
  "version": "0.1.2",
  "description": "Process Control Temperature - Web App for Android Tablets",
  "main": "main.js",
  "scripts": {
    "prestart": "node scripts/ensure-utf8.js",
    "start": "electron .",
    "dev": "electron . --dev",
    "web": "node server.js",
    "web-dev": "nodemon server.js",
    "build": "electron-builder",
    "build-win": "electron-builder --win",
    "build-all": "electron-builder --win --mac --linux",
    "rebuild-hid": "electron-rebuild -f -w node-hid"
  },
  "keywords": [
    "electron",
    "com-port",
    "process-control-temperature",
    "serial",
    "web-app",
    "android",
    "pwa"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "electron": "^38.2.2",
    "electron-builder": "^24.13.3",
    "jimp": "^1.6.0",
    "nodemon": "^3.1.10",
    "to-ico": "^1.0.1"
  },
  "dependencies": {
    "chart.js": "^4.4.4",
    "electron-updater": "^6.6.2",
    "express": "^4.21.2",
    "node-hid": "^3.1.1",
    "occt-import-js": "^0.0.23",
    "serialport": "^12.0.0",
    "three": "^0.181.1"
  },
  "build": {
    "appId": "com.processcontrol.temperature-app",
    "productName": "Process Control Temperature App",
    "publish": {
      "provider": "github",
      "owner": "MuhammdAbdullah",
      "repo": "Process-Control-App"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "index-web.html",
      "renderer-web.js",
      "admin.html",
      "chart.html",
      "splash.html",
      "simulation.html",
      "curriculum.html",
      "lab1.html",
      "lab2.html",
      "lab3.html",
      "lab4.html",
      "lab5.html",
      "chart-page.js",
      "responsive-scaling.js",
      "server.js",
      "manifest.json",
      "package.json",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    }
  }
}
